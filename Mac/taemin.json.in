{
    "title": "Taemin's configurations",
    "rules": [
        {
            "description": "Left shift + right shift -> Caps Lock",
            "manipulators": [
                {
                    "from": {
                        "key_code": "left_shift",
                        "modifiers": {
                            "mandatory": ["right_shift"],
                            "optional": ["caps_lock"]
                        }
                    },
                    "to": [{"key_code": "caps_lock"}],
                    "type": "basic"
                },
                {
                    "from": {
                        "key_code": "right_shift",
                        "modifiers": {
                            "mandatory": ["left_shift"],
                            "optional": ["caps_lock"]
                        }
                    },
                    "to": [{"key_code": "caps_lock"}],
                    "type": "basic"
                }
            ]
        },
        {
            "description": "Left shift + space -> Option + space",
            "manipulators": [
                {
                    "type": "basic",
                    "from": {
                        "key_code": "spacebar",
                        "modifiers": {
                            "mandatory": [
                                "left_shift"
                            ]
                        }
                    },
                    "to": {
                        "key_code": "spacebar",
                        "modifiers": [
                            "right_alt"
                        ]
                    }
                }
            ]
        },
        {
            "description": "Left arrow -> right control in terminal",
            "manipulators": [
                {
                    "type": "basic",
                    "from": {
                        "key_code": "left_arrow",
                        "modifiers": {
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "right_control"
                        }
                    ],
                    "conditions": IS_TERMINAL
                },
                {
                    "type": "basic",
                    "from": {
                        "key_code": "i",
                        "modifiers": {
                            "mandatory": [
                                "fn"
                            ],
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "up_arrow"
                        }
                    ],
                    "conditions": IS_TERMINAL
                },
                {
                    "type": "basic",
                    "from": {
                        "key_code": "j",
                        "modifiers": {
                            "mandatory": [
                                "fn"
                            ],
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "left_arrow"
                        }
                    ],
                    "conditions": IS_TERMINAL
                },
                {
                    "type": "basic",
                    "from": {
                        "key_code": "k",
                        "modifiers": {
                            "mandatory": [
                                "fn"
                            ],
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "down_arrow"
                        }
                    ],
                    "conditions": IS_TERMINAL
                },
                {
                    "type": "basic",
                    "from": {
                        "key_code": "l",
                        "modifiers": {
                            "mandatory": [
                                "fn"
                            ],
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "right_arrow"
                        }
                    ],
                    "conditions": IS_TERMINAL
                }
            ]
        }
    ]
}
